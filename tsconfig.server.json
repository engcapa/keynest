{
  "compilerOptions": {
    "outDir": "server-dist",
    "rootDir": "server",
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noEmit": false
  },
  "include": ["server/**/*"],
  "exclude": ["node_modules"]
}
