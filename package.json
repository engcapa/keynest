  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --port 8081",
    "web": "expo start --web --port 8081",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "server": "npx tsx server/index.ts",
    "build:web": "expo export --platform web",
    "bundle:web": "node scripts/bundle-web.mjs",
    "build:server": "tsc --project tsconfig.server.json",
    "build": "npm run build:web && npm run bundle:web && npm run build:server",
    "serve": "npm run build:web && npm run bundle:web && npm run server"
